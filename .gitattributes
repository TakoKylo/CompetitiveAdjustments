# Default: auto-detect text files and normalize to LF in the repo.
# Working tree gets the platform-native line ending on checkout.
* text=auto eol=lf

# Source files: explicitly LF in the repo.
*.cs        text eol=lf
*.csproj    text eol=lf
*.json      text eol=lf
*.md        text eol=lf
*.gitignore text eol=lf

# Binary files: never touch line endings.
*.dll       binary
*.pdb       binary
*.png       binary
*.jpg       binary
*.unity3d   binary
*.bundle    binary
